{
  "name": "jaana-sjbhs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n client,server -c blue,green \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "nodemon -L --watch server --ext ts --exec \"node --loader ts-node/esm --experimental-specifier-resolution=node\" server/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "tsc --noEmit && vite build --outDir dist/client",
    "build:server": "tsc --project tsconfig.server.json",
    "check:vercel": "tsc --project tsconfig.vercel.json",
    "build:vercel": "npm run check:vercel && npm run build:client",
    "preview": "vite preview",
    "start": "node dist/server/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3",
    "vite": "^4.5.5"
  }
}
